APP_NAME="BTC TimesFM Dashboard"
DEFAULT_EXCHANGE="binance"
DEFAULT_SYMBOL="BTC/USDT"
DEFAULT_TIMEFRAME="5m"
DEFAULT_LOOKBACK=1024
DEFAULT_HORIZON=24
MAX_LOOKBACK=16000
MAX_HORIZON=1000
MODEL_CHECKPOINT="google/timesfm-2.5-200m-pytorch"
MODEL_MAX_CONTEXT=2048
MODEL_MAX_HORIZON=256
USE_QUANTILES=true
SQLITE_PATH="./btc_timesfm.db"
DEV_FAKE_FORECAST=false
INFERENCE_DEVICE="cpu"

